# LLM endpoint — OpenAI-compatible. PRODUCTION MUST BE IN-KINGDOM (PDPL, see docs/build-plan.md §6).
# Local dev with Ollama:  RADD_LLM_BASE_URL=http://localhost:11434/v1  RADD_LLM_API_KEY=ollama
# vLLM on KSA cloud:      RADD_LLM_BASE_URL=https://<your-vllm-host>/v1
RADD_LLM_BASE_URL=http://localhost:11434/v1
RADD_LLM_API_KEY=ollama
RADD_MODEL=qwen2.5:14b
RADD_MAX_TOKENS=2048
